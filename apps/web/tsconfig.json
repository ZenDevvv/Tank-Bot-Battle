{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    },
    "types": [
      "vite/client",
      "jest",
      "@testing-library/jest-dom"
    ]
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": [
    "src",
    "vite.config.ts"
  ]
}
